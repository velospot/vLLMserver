# Development Environment Configuration (macOS/No GPU)
# Use: source .env.dev before running dev commands
# Or: ./scripts/start.sh dev (auto-loads this)

# ── Chat Model ─────────────────────────────────────────────────────────────
CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ
CHAT_GPU_MEM_UTIL=0.5              # Reduced for development
CHAT_MAX_MODEL_LEN=2048            # Smaller context for faster testing
CHAT_MAX_NUM_SEQS=32               # Smaller batch for dev
CHAT_TENSOR_PARALLEL=1
CHAT_DTYPE=auto
# CHAT_QUANTIZATION=                # Auto-detect

# ── Embedding Model (optional) ─────────────────────────────────────────────
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_GPU_MEM_UTIL=0.2
# EMBEDDING_MAX_MODEL_LEN=512
# EMBEDDING_TENSOR_PARALLEL=1

# ── Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=debug                    # Verbose logging for development

# ── Development Features ───────────────────────────────────────────────────
# Enable debug mode in your IDE
DEBUG=true
PYTHONUNBUFFERED=1                # Immediate log output
PYTHONDONTWRITEBYTECODE=1         # No .pyc files during development

# ── Testing ────────────────────────────────────────────────────────────────
# Override PORT for test server (to avoid conflicts)
# TEST_PORT=8001

# ── Rate Limiting (Relaxed for Development) ────────────────────────────────
# RATE_LIMIT_RPM=100               # Requests per minute
# RATE_LIMIT_TPM=500000            # Tokens per minute
# RATE_LIMIT_TPD=50000000          # Tokens per day
