# Production Environment Configuration (Linux + NVIDIA GPU)
# Use: source .env.prod before running prod commands
# Or: ./scripts/start.sh prod (auto-loads this)
# Requirements: Linux, CUDA 12.1+, NVIDIA GPU

# ── Chat Model ─────────────────────────────────────────────────────────────
CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ
CHAT_GPU_MEM_UTIL=0.9              # High GPU utilization for production
CHAT_MAX_MODEL_LEN=4096            # Full context window
CHAT_MAX_NUM_SEQS=256              # Higher batch for throughput
CHAT_TENSOR_PARALLEL=1             # Increase if using multi-GPU
CHAT_DTYPE=bfloat16                # Mixed precision for speed
# CHAT_QUANTIZATION=awq            # Optional: AWQ quantization

# ── Embedding Model (optional) ─────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_GPU_MEM_UTIL=0.1         # Smaller allocation, primary on chat
EMBEDDING_MAX_MODEL_LEN=512
EMBEDDING_TENSOR_PARALLEL=1

# ── Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info                     # Production logging

# ── Production Security ────────────────────────────────────────────────────
# API key validation enabled (see app/auth.py)
# Configure these in your deployment secrets manager
# API_KEY_1=sk-prod-primary
# API_KEY_2=sk-prod-secondary

# ── Rate Limiting (Strict for Production) ──────────────────────────────────
RATE_LIMIT_RPM=60                  # Requests per minute
RATE_LIMIT_TPM=100000              # Tokens per minute
RATE_LIMIT_TPD=10000000            # Tokens per day

# ── Performance Tuning ─────────────────────────────────────────────────────
# Increase for higher throughput (if GPU VRAM allows)
# CHAT_MAX_NUM_SEQS=512
# EMBEDDING_GPU_MEM_UTIL=0.2

# For multi-GPU setups
# CHAT_TENSOR_PARALLEL=2            # 2 GPUs
# EMBEDDING_TENSOR_PARALLEL=1

# ── Monitoring & Logging ───────────────────────────────────────────────────
# Prometheus metrics enabled at /metrics
# Log format: structured JSON for log aggregation
# Consider using log aggregation (CloudWatch, Datadog, etc.)

# ── Environment ────────────────────────────────────────────────────────────
# SHOULD be set by deployment platform (Kubernetes, Docker, etc.)
ENVIRONMENT=production

# ── CUDA/PyTorch Multiprocessing Settings ──────────────────────────────
# These are hints/suggestions; actual behavior depends on vLLM version
# CUDA_LAUNCH_BLOCKING=0  # Default: async (faster, may cause race conditions)
# CUDA_LAUNCH_BLOCKING=1  # Sync mode (slower, better for debugging)
