# ── Chat model ──────────────────────────────────────────────────────────────
CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ
CHAT_GPU_MEM_UTIL=0.7          # fraction of GPU VRAM for chat model
CHAT_MAX_MODEL_LEN=4096        # context window (tokens)
CHAT_MAX_NUM_SEQS=256          # max concurrent sequences in the batch
CHAT_TENSOR_PARALLEL=1         # number of GPUs for tensor parallelism
CHAT_DTYPE=auto                # auto | float16 | bfloat16
# CHAT_QUANTIZATION=awq        # set only if auto-detection fails

# ── Embedding model (comment out to disable) ─────────────────────────────────
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_GPU_MEM_UTIL=0.2
# EMBEDDING_MAX_MODEL_LEN=512
# EMBEDDING_TENSOR_PARALLEL=1

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
